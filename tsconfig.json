{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@app/*": ["app/src/*"],
      "@core/*": ["core/*"],
      "@ai/*": ["ai/*"],
      "@db/*": ["db/*"],
      "@report/*": ["report/*"],
      "@pw/*": ["playwright/*"]
    }
  },
  "include": ["app/src", "electron", "core", "ai", "playwright", "db", "report", "config", "vite.config.ts"]
}
